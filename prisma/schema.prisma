generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "darwin", "darwin-arm64", "windows"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String       @id @default(uuid())
  username   String       @unique
  password   String
  role       String       @default("user")
  hypotheses Hypothesis[] // Связь: один юзер -> много гипотез
}

model Hypothesis {
  id             String   @id @default(uuid())
  authorId       String
  author         User     @relation(fields: [authorId], references: [id])
  title          String?
  description    String?
  assignee       String?
  status         String?
  createdAt      Float?   // Float отлично вмещает Timestamp Date.now()
  metricName     String?
  targetAudience String?
  pointA         Float?
  pointB         Float?
  actualPointB   Float?
  resultComment  String?
  durationValue  Int?
  durationUnit   String?
  priority       String?
  startedAt      Float?

  // Связь: одна гипотеза -> много замеров
  progressHistory ProgressRecord[] 
}

// Новая таблица для истории замеров
model ProgressRecord {
  id           String     @id @default(uuid())
  hypothesisId String
  hypothesis   Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)
  date         Float
  value        Float
}